# Local-development environment for go-oikumenea TOOLING.
#
# Copy to `.env` (gitignored) and tweak for your machine:  cp .env.example .env
#
# IMPORTANT: the *server itself* does NOT read this file. Witchcraft reads its connection
# string + environment from var/conf/install.yml (ECV/refreshable config). This .env feeds the
# out-of-process tooling instead:
#   - Atlas        (`atlas migrate apply --env local` reads $DATABASE_URL — see atlas.hcl)
#   - docker compose (`docker-compose.dev.yml` interpolates $OIKU_DB_HOST_PORT)
#   - integration tests (`go test -tags integration` reads $OIKUMENEA_TEST_DSN)
# Keep the DSNs here in sync with var/conf/install.yml's postgres.dsn.

# Host port the docker-compose.dev.yml Postgres publishes. Change if 5432 is taken locally
# (then update the DSNs below to match).
OIKU_DB_HOST_PORT=5432

# Operator DB connection Atlas applies migrations to (env "local" in atlas.hcl).
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres?sslmode=disable

# DSN the //go:build integration tests connect to (internal/<module>/*_integration_test.go).
OIKUMENEA_TEST_DSN=postgres://postgres:dev@localhost:5432/postgres?sslmode=disable

# Deployment-environment RID segment; must match var/conf/install.yml `environment`
# (it is baked into every RID via the app.environment GUC — D-ResourceIdentifiers).
OIKU_ENVIRONMENT=local
