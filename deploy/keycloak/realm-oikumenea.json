{
  "realm": "oikumenea",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 1800,
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "oikumenea",
      "name": "go-oikumenea API client (local dev)",
      "description": "Public dev client: direct-access grant for curl + standard flow. The audience mapper adds aud=oikumenea so the app's audience check passes.",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocolMappers": [
        {
          "name": "oikumenea-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "oikumenea",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "person-code",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "person_code",
            "claim.value": "admin",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@oikumenea.test",
      "firstName": "Local",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-oikumenea"]
    }
  ]
}
