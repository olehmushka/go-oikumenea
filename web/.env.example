# go-oikumenea web admin console — environment (D-WebUI).
# Copy to .env.local for `npm run dev`. All values below are LOCAL-DEV defaults.

# --- The go-oikumenea API (server-to-server target of the BFF proxy) ---
API_BASE_URL="https://localhost:8443"
# The dev API serves a self-signed cert (witchcraft WithSelfSignedCertificate).
# DEV ONLY: let the Next.js server trust it. Do NOT set this in production.
NODE_TLS_REJECT_UNAUTHORIZED="0"

# --- Auth.js (NextAuth v5) ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET="dev-only-change-me-please-0000000000000000000="
# The public origin the browser uses to reach this app.
AUTH_URL="http://localhost:8445"
# Trust the forwarded host/port (needed behind the 8445 mapping).
AUTH_TRUST_HOST="true"

# --- Keycloak (the oikumenea-web confidential client) ---
AUTH_KEYCLOAK_ID="oikumenea-web"
AUTH_KEYCLOAK_SECRET="dev-oikumenea-web-secret"
# Must match the token `iss` exactly and be reachable from BOTH browser and this server.
AUTH_KEYCLOAK_ISSUER="http://localhost:8080/realms/oikumenea"
